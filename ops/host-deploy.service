[Unit]
Description=jekko host auto-deploy (one-shot per timer trigger)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/home/ubuntu/jekko/ops/host-deploy.sh once
# Inherit a normal shell env so cargo/rustup are on PATH.
Environment=PATH=/home/ubuntu/.cargo/bin:/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/ubuntu/jekko
Nice=10

[Install]
WantedBy=default.target
