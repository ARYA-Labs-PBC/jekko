#!/usr/bin/env bash
# Mandatory pre-push gate. Mirrors the fast local CI lane.
set -euo pipefail

if [[ "${JANKURAI_SKIP_PREPUSH:-0}" == "1" ]]; then
  printf '\033[1;33m!! JANKURAI_SKIP_PREPUSH=1 set — skipping local CI gate\033[0m\n' >&2
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

bash ops/ci/quality-gates.sh
