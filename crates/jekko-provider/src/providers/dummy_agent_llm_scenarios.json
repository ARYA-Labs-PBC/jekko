{
  "scenarios": [
    {
      "id": "default",
      "title": "Deterministic text response",
      "description": "A stable, zero-cost assistant reply for local agent workflow tests.",
      "tags": [
        "deterministic",
        "text",
        "offline"
      ],
      "provider": "dummy_agent_llm",
      "model": "default",
      "frames": [
        {
          "type": "stream-start",
          "model": "dummy_agent_llm/default"
        },
        {
          "type": "text-delta",
          "text": "dummy_agent_llm deterministic response"
        },
        {
          "type": "usage",
          "input_tokens": 0,
          "output_tokens": 0,
          "cache_read_tokens": 0,
          "cache_write_tokens": 0
        },
        {
          "type": "stream-end",
          "stop_reason": "stop"
        }
      ]
    },
    {
      "id": "tool-call",
      "title": "Deterministic read-tool call",
      "description": "Emits one completed Read tool call, then emits a deterministic final answer when the runtime sends the tool result in the next round.",
      "tags": [
        "deterministic",
        "tool-call",
        "offline"
      ],
      "provider": "dummy_agent_llm",
      "model": "tool-call",
      "frames": [
        {
          "type": "stream-start",
          "model": "dummy_agent_llm/tool-call"
        },
        {
          "type": "text-delta",
          "text": "I will inspect the requested file."
        },
        {
          "type": "tool-call-start",
          "id": "call_dummy_read_1",
          "name": "Read"
        },
        {
          "type": "tool-call-input-delta",
          "id": "call_dummy_read_1",
          "delta": "{\"path\":\"README.md\"}"
        },
        {
          "type": "tool-call-end",
          "id": "call_dummy_read_1",
          "name": "Read",
          "input": {
            "path": "README.md"
          }
        },
        {
          "type": "usage",
          "input_tokens": 0,
          "output_tokens": 0,
          "cache_read_tokens": 0,
          "cache_write_tokens": 0
        },
        {
          "type": "stream-end",
          "stop_reason": "tool_calls"
        }
      ],
      "after_tool_frames": [
        {
          "type": "stream-start",
          "model": "dummy_agent_llm/tool-call"
        },
        {
          "type": "text-delta",
          "text": "Read completed; dummy_agent_llm has the deterministic tool result."
        },
        {
          "type": "usage",
          "input_tokens": 0,
          "output_tokens": 0,
          "cache_read_tokens": 0,
          "cache_write_tokens": 0
        },
        {
          "type": "stream-end",
          "stop_reason": "stop"
        }
      ]
    },
    {
      "id": "error",
      "title": "Deterministic provider failure",
      "description": "Returns a provider error after stream start so retry and failure paths can be tested without network.",
      "tags": [
        "deterministic",
        "error",
        "offline"
      ],
      "provider": "dummy_agent_llm",
      "model": "error",
      "frames": [
        {
          "type": "stream-start",
          "model": "dummy_agent_llm/error"
        },
        {
          "type": "error",
          "message": "dummy_agent_llm scripted failure"
        }
      ]
    }
  ]
}
