{
  "id": "tool-read",
  "title": "Read-tool loop",
  "tags": ["deterministic", "tool-call", "streaming"],
  "provider": "dummy_agent_llm",
  "model": "tool-read",
  "stages": [
    {
      "when": "initial",
      "frames": [
        { "type": "stream-start" },
        {
          "type": "metadata",
          "metadata": {
            "provider": "dummy_agent_llm",
            "scenario_id": "tool-read",
            "network": false,
            "api_key_required": false
          }
        },
        {
          "type": "text-delta",
          "text": "dummy_agent_llm/tool-read: requesting a deterministic read."
        },
        {
          "type": "tool-call",
          "id": "dummy-read-1",
          "name": "read",
          "input": {
            "filePath": "{{first_path}}",
            "offset": 1,
            "limit": 20
          }
        },
        {
          "type": "usage",
          "input_tokens": 0,
          "output_tokens": 0,
          "cache_read_tokens": 0,
          "cache_write_tokens": 0
        },
        { "type": "stream-end", "stop_reason": "tool-calls" }
      ]
    },
    {
      "when": "after-tool-result",
      "frames": [
        { "type": "stream-start" },
        {
          "type": "metadata",
          "metadata": {
            "provider": "dummy_agent_llm",
            "scenario_id": "tool-read",
            "stage": "after-tool-result",
            "network": false,
            "api_key_required": false
          }
        },
        {
          "type": "text-delta",
          "text": "dummy_agent_llm/tool-read: tool result received."
        },
        {
          "type": "usage",
          "input_tokens": 0,
          "output_tokens": 0,
          "cache_read_tokens": 0,
          "cache_write_tokens": 0
        },
        { "type": "stream-end", "stop_reason": "stop" }
      ]
    }
  ]
}
