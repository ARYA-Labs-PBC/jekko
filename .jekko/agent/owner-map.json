{
  "version": 1,
  "owners": [
    {
      "id": "sdk",
      "paths": [
        "packages/sdk/**"
      ],
      "responsibility": "Software Development Kits, including the JavaScript SDK."
    },
    {
      "id": "core",
      "paths": [
        "packages/core/**",
        "packages/jekko/**"
      ],
      "responsibility": "Core shared logic, backend services, and primary Jekko package components."
    },
    {
      "id": "extensions_plugins",
      "paths": [
        "packages/extensions/**",
        "packages/plugin/**"
      ],
      "responsibility": "Extensions and plugin system for Jekko."
    },
    {
      "id": "tooling_infra",
      "paths": [
        "infra/**",
        "nix/**",
        "script/**",
        "github/**"
      ],
      "responsibility": "Infrastructure, CI/CD, build scripts, and Nix configurations."
    }
  ]
}
