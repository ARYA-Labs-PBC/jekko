# Ambitious Redis-to-Jedis port foundry. Stage generation is runtime-derived
# from target evidence; this runbook intentionally does not list Redis stages.
<<<ZYAL v1:daemon id=redis-jedis-port-foundry>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Redis to Jedis port foundry"
  objective: |
    Build Jedis as a 100% Rust replacement with Redis behavior parity. Discover
    behavior from the reference target, public docs, tests, examples, and
    command compatibility evidence; generate stages at runtime; execute bounded
    worker lanes; enforce Jankurai; and close correctness/performance gaps with
    RedlineDB-style parity artifacts.
  risk:
    - "Reference source is behavior evidence only; do not copy implementation text."
    - "Do not mutate the Redis reference repository."
    - "Do not bake a Redis stage list into this runbook."

port:
  target: "Redis"
  replacement: "Jedis"
  target_repo: "./references/redis"
  replacement_repo: "."
  worker_cap: 10
  resume_store: sqlite
  require_clean_start: true
  stage_strategy: runtime_generated_from_evidence
  stop_on:
    - dirty_primary_worktree
    - destructive_target_repo_operation
    - live_budget_expired
    - jankurai_hard_regression
    - repeated_worker_quarantine

advanced_reasoning:
  enabled: true
  worker_cap: 10
  confidence_cap_without_executable_evidence: 0.35
  store_raw_reasoning: false
  blind_lanes: true
  strategy_diversity_required: true
  reducer:
    model: jnoccio/power-winner
    may_only_combine_verified_artifacts: true
  memory:
    write_positive_after: verifier_approval
    write_negative_after: falsifying_evidence
    poison_guard: true

repo_graph:
  enabled: true
  store: sqlite
  export: "target/zyal/reasoning/${run.id}/reasoning-graph.json"
  nodes: [files, docs, tests, modules, functions, structs, enums, impls, methods, commands, parity_cases]
  edges: [contains, imports, calls, tests, derives_from, parity_covers, phase_owns, changed_by]
  feed_workers: true

parity_lab:
  enabled: true
  style: redlinedb
  artifact_dir: "target/zyal/parity/${run.id}"
  cases_dir: "tests/parity/redis"
  approved_cases_only: true
  raw_results: raw.jsonl
  summary: summary.json
  gaps: gaps.json
  adapters:
    reference:
      target_kind: redis
      repo: "./references/redis"
      command: "./src/redis-server --save '' --appendonly no"
      read_only: true
    candidate:
      target_kind: jedis
      repo: "."
      command: "cargo run --bin jedis -- --save '' --appendonly no"
  required_tags: [required, approved]
  perf_budget:
    default_p95_ms_max_ratio: 1.25
  fail_on:
    - zero_cases
    - missing_required_case
    - skipped_required_case
    - failed_case
    - missing_perf_data
    - perf_ratio_over_budget

jankurai_gate:
  command: "rtk jankurai audit . --mode advisory --json .jankurai/repo-score.json --md .jankurai/repo-score.md"
  max_new_hard_findings: 0
  max_score_drop: 0
  block_cap_regression: true

sandbox:
  workers:
    isolation: git_worktree
    root: ".zyal/worktrees/${run.id}"
    max_workers: 10
    disjoint_write_scopes_required: true
  target_repos:
    default: read_only
    destructive_operations: deny

fleet:
  max_workers: 10
  heartbeat_interval: 20s
  jnoccio:
    enabled: true
    register_workers: true
    max_instances: 10

model_policy:
  routine: jnoccio/routine
  power: jnoccio/power-winner
  use_routine_for: [frame, stage_brainstorm, phase_brainstorm, hypothesis, verifier, memory_curate, parity_generate]
  use_power_for: [stage_reduce, critic, perf_close, hard_escalation]
  record_reliability: true
  paid_live_calls_default: false

workflow:
  states:
    - capture_target
    - frame_request
    - retrieve_context
    - brainstorm_stages
    - critique_stages
    - finalize_master_plan
    - track_stage
    - brainstorm_phase
    - finalize_phase_plan
    - build_phase
    - verify_phase
    - heal_integration
    - generate_parity
    - close_parity_perf
    - complete
  persist: sqlite
  receipts: "target/zyal/runs/${run.id}/events.jsonl"
  stop_file: "target/zyal/runs/${run.id}/STOP"

observability:
  daemon_status:
    include:
      - run_id
      - current_reasoning_state
      - active_lanes
      - last_event
      - parity_gap_count
      - last_jankurai_score
      - model_reliability_winners
  artifacts:
    reasoning_graph: "target/zyal/reasoning/${run.id}/reasoning-graph.json"
    parity_raw: "target/zyal/parity/${run.id}/raw.jsonl"
    parity_summary: "target/zyal/parity/${run.id}/summary.json"
    parity_gaps: "target/zyal/parity/${run.id}/gaps.json"

done:
  require:
    - target_request_captured
    - master_plan_generated_from_runtime_evidence
    - phases_complete
    - jankurai_gate_passed
    - parity_gate_passed
    - perf_budgets_checked
  forbid:
    - baked_redis_stage_list
    - model_only_claim
    - copied_reference_implementation
    - missing_required_parity_case
    - skipped_required_parity_case
    - unchecked_perf_budget
<<<END_ZYAL id=redis-jedis-port-foundry>>>
ZYAL_ARM RUN_FOREVER id=redis-jedis-port-foundry
