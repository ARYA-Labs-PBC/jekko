# ZYAL v2.6 - Insane semantic improvement finder
#
# Full fleet with dispatch, research, security, sandboxing, measurable KPI
# gates, and critic review that can approve push or reject/revert with saved
# patch receipts.

<<<ZYAL v1:daemon id=semantic-improvement-finder-insane>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Semantic improvement finder insane"
  objective: |
    Run a full-power improvement fleet. Route candidate improvements by
    category, keep counterexamples and proofs in memory, quarantine tainted
    inputs, save the candidate patch before review, and only promote when tests,
    baseline KPI, after KPI, behavior-equivalence proof, burden/risk checks,
    rollback notes, candidate patch, and PR evidence all line up.
  risk:
    - full-power dispatch can amplify false greens if the proof lane is weak
    - hidden burden can creep back in when simplification, speed, or security is
      measured loosely

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, host_ui_button, signed_cli_input]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 5s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

stop:
  all:
    - git_clean:
        allow_untracked: false

context:
  strategy: hybrid
  compact_every: 4
  hard_clear_every: 8
  preserve:
    - objective
    - current_improvement
    - improvement_hypothesis
    - baseline_kpi
    - proof_command
    - candidate_patch

dispatch:
  enabled: true
  classifier:
    command: "node scripts/dispatch-classifier.mjs"
    timeout: 30s
    write_to: target/jankurai/dispatch/route.json
  lanes:
    - id: simplification
      dispatch_to: experiments
      description: "Code-size and surface-area reductions"
    - id: speed
      dispatch_to: experiments
      description: "Latency and throughput improvements"
    - id: memory
      dispatch_to: experiments
      description: "Peak-memory and allocation reductions"
    - id: security-no-burden
      dispatch_to: security
      description: "Security improvements that do not add review burden"
    - id: dependency-surface
      dispatch_to: research
      description: "Dependency and toolchain-surface reduction"
    - id: dead-code
      dispatch_to: fan_out
      description: "Dead-code elimination and consolidation"
    - id: api-friction
      dispatch_to: approvals.gates.improvement_review
      description: "Frictions that need human approval before promotion"
    - id: random-deep-dive
      dispatch_to: fan_out
      description: "Random deep-dive improvement hunting"
  default_lane: simplification
  on_no_match: default

fleet:
  max_workers: 12
  isolation: hybrid
  jnoccio:
    enabled: true
    base_url: "http://127.0.0.1:4317"
    register_workers: true
    heartbeat_interval: 20s
    max_instances: 12
  telemetry:
    publish_to: jnoccio
    headers:
      x-jekko-run-id: "${run.id}"
      x-jekko-session: "${session.id}"
      x-jekko-process-role: worker

agents:
  supervisor:
    agent: plan
  workers:
    - id: simplification-worker
      count: 3
      agent: build
      isolation: git_worktree
    - id: speed-worker
      count: 2
      agent: build
      isolation: git_worktree
    - id: memory-worker
      count: 2
      agent: build
      isolation: git_worktree
    - id: security-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: research-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: dispatch-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: deep-dive-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: critic-review-worker
      count: 1
      agent: critic
      isolation: same_session

models:
  profiles:
    plan:
      provider: anthropic
      model: claude-opus-4-7
      reasoning: true
    build:
      provider: anthropic
      model: claude-sonnet-4-6
    critic:
      provider: openai
      model: gpt-5
      reasoning: true
    researcher:
      provider: google
      model: gemini-2-pro
  routes:
    plan: plan
    implement: build
    review: critic
    research: researcher
  critic:
    must_differ_from_builder: true
    must_use_different_provider: true
  redundancy:
    on_rate_limit: plan
    on_context_overflow: critic
    chain: [plan, build, critic]
    cooldown: 30s
  confidence_cap: 0.45

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_substitutes: true
    block_ts_ignore: true
  diff_budget:
    max_files_changed: 20
    max_added_lines: 1200
    on_violation: require_approval
  checks:
    - name: no-test-skip
      pattern: "\\.skip\\(|test\\.only\\(|describe\\.only\\("
      scope: file_diff
      on_violation: block_promotion
    - name: no-false-green
      pattern: "expect\\(true\\)|always passes"
      scope: file_diff
      on_violation: warn
    - name: no-contract-drift
      pattern: "SPEC\\.md|VERSION\\.md"
      scope: file_diff
      on_violation: warn

experiments:
  strategy: portfolio_search
  fork_from: last_green_checkpoint
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.35
    axes: [simplification, speed, memory, security, burden, dependency-surface, dead-code, api-friction]
  lanes:
    - id: simplification
      hypothesis: "Remove code while preserving behavior and extension seams."
      isolation: git_worktree
      timeout: 30m
      budget:
        max_iterations: 2
        max_diff_lines: 180
        max_cost_usd: 1.50
    - id: speed
      hypothesis: "Profile-guided speedups beat speculative rewrites."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.75
    - id: memory
      hypothesis: "Peak-memory improvements should be measured on deterministic fixtures."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.75
    - id: security-no-burden
      hypothesis: "Security improvements should shrink the permission surface without burden growth."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 200
        max_cost_usd: 1.50
    - id: dependency-surface
      hypothesis: "Reducing dependency surface lowers burden and review cost."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 200
        max_cost_usd: 1.50
    - id: dead-code
      hypothesis: "Dead-code elimination should stay behavior-preserving and measurable."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
    - id: api-friction
      hypothesis: "API-friction fixes need review because they can mask behavior change."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
    - id: random-deep-dive
      hypothesis: "Random deep dives uncover low-regret improvements missed by strict triage."
      isolation: git_worktree
      timeout: 60m
      budget:
        max_iterations: 3
        max_diff_lines: 280
        max_cost_usd: 2.25
  max_parallel: 6
  scoring:
    weights:
      tests_passed: 0.25
      kpi_gain: 0.2
      behavior_equivalence: 0.2
      complexity_reduction: 0.15
      security_delta: 0.1
      rollback_simplicity: 0.1
    primary: best_verified_improvement
    goal_direction: maximize
    judge:
      agent: critic-review-worker
      blind: true
      must_use_different_provider: true
  reduce:
    strategy: synthesize_best
    require_final_verification: true
  preserve_failed_lanes_as_negative_memory: true

research:
  version: v1
  mode: mixed
  autonomy: require_plan
  max_parallel: 4
  timeout_seconds: 60
  provider_policy:
    prefer: [official_api, primary_source, privacy_first]
    allow: [openalex, arxiv, github, tavily, exa, firecrawl, jina]
    missing_provider: skip_with_receipt
  extraction:
    enabled: true
    max_pages: 10
    allowed_extractors: [built_in, jina]
  evidence:
    require_citations: true
    claim_level: true
    store: sqlite
  safety:
    redact_secrets: true
    block_internal_urls: true
    prompt_injection: quarantine
    taint_label: web_content
  budgets:
    max_queries: 40
    max_pages: 30
    max_cost_usd: 15
  paper_scan:
    enabled: true
    domains: [arxiv.org, openreview.net]
    queries: ["code simplification metrics", "behavior equivalence testing", "semantic improvement"]
    open_access: preferred
    max_papers: 8
    output_root: ".jekko/daemon/research"
    raw_receipts: ".jekko/daemon/research/raw"
  full_text:
    enabled: true
    store: checked_in_json
    raw_receipts: ".jekko/daemon/research/raw"
    extraction_receipts: ".jekko/daemon/research/extracted"
    license_policy: oa_only
  dedupe:
    enabled: true
    state_root: ".jekko/daemon/research/dedupe"
    duplicate_policy: skip_existing
    hash_keys: [url, title, publication_hash]
  context_packing:
    strategy: hard
    target_fill_ratio: 0.8
    output_reserve_tokens: 1600
    safe_window_tokens: 800
  question_bank:
    output_root: ".jekko/daemon/question-bank"
    papers_root: ".jekko/daemon/question-bank/papers"
    challenges_root: ".jekko/daemon/question-bank/challenges"
    rejected_root: ".jekko/daemon/question-bank/rejected"
    acceptance:
      min_auditor_agreement: 0.8
      min_answerability: 0.7
      max_blind_correct_rate_for_hard: 0.25
      reject_if_ambiguous: true
  agent_trials:
    question_generators: 2
    answerers: 2
    model_profile: researcher
  audit:
    critics: 2
    focused_auditors: 2
    min_auditor_agreement: 0.8
    min_answerability: 0.7

memory:
  stores:
    counterexamples:
      scope: task
      retention: until_archive
      write_policy: append_only
      read_policy: inject_at_start
      searchable: true
    proofs:
      scope: repo
      retention: permanent
      write_policy: upsert
      read_policy: search
      searchable: true
    improvement_receipts:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
    candidate_patches:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
    rollback_notes:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
  redaction:
    patterns:
      - "(token|secret|password|credential)"
    action: mask
  provenance:
    track_source: true
    hash_chain: true

evidence:
  require_before_promote:
    - type: improvement_hypothesis
      must_exist: true
    - type: baseline_kpi
      must_exist: true
    - type: after_kpi
      must_exist: true
    - type: behavior_equivalence_proof
      must_pass: true
    - type: kpi_delta
      must_exist: true
    - type: burden_delta
      must_exist: true
    - type: proof_command
      must_pass: true
    - type: candidate_patch
      must_exist: true
    - type: rollback_note
      must_exist: true
    - type: pr_evidence
      must_exist: true

taint:
  default_label: untrusted
  labels:
    untrusted:
      rank: untrusted
    untrusted_for_arming:
      rank: untrusted_for_arming
    trusted_user:
      rank: high
    repo_file:
      rank: medium
    tool_output:
      rank: untrusted
    mcp_resource:
      rank: untrusted
    web_content:
      rank: untrusted_for_arming
    assistant_generated:
      rank: untrusted
    hostile:
      rank: hostile
  forbid:
    - from: [untrusted, untrusted_for_arming, hostile]
      cannot: [arm, approve, grant_capability, write_memory_procedural, write_memory_semantic, exec_shell, install_skill, modify_objective, expose_secret]
      unless: [signed_sanitizer]
  prompt_injection:
    detect_patterns:
      - "[Ii]gnore previous instructions"
      - "[Ss]ystem prompt"
      - "[Tt]ool output"
      - "[Ee]xfiltrate"
    on_detect: pause
    scan_sources: [tool_output, web_content, mcp_resource]

sandbox:
  paths:
    - path: "packages/jekko/src/**"
      access: write
    - path: "docs/ZYAL/**"
      access: write
    - path: "agent/**"
      access: write
  network:
    outbound: allowlist
    allowlist: ["http://127.0.0.1:4317", "https://github.com", "https://api.github.com"]
  resources:
    max_file_size: "1000000"
    max_total_disk: "50000000"
    max_memory: "2000000000"
    max_processes: 12
  env_inherit: [PATH, HOME, USER]
  env_deny: [GITHUB_TOKEN, OPENAI_API_KEY, ANTHROPIC_API_KEY]

security:
  trust_zones:
    repo:
      paths: ["packages/jekko/**", "docs/ZYAL/**", "agent/**"]
      require_approval: false
      max_risk_score: 0.5
    generated:
      paths: ["docs/ZYAL/SPEC.md", "agent/repo-score.json", "agent/repo-score.md"]
      require_approval: true
      max_risk_score: 0.1
  injection:
    scan_inputs: true
    scan_outputs: true
    deny_patterns: ["[Ii]gnore previous instructions", "[Ee]xfiltrate", "[Ss]ystem prompt"]
    on_detect: pause
  secrets:
    allowed_env: [PATH, HOME, USER]
    redact_from_logs: true
    rotate_after: 24h

observability:
  spans:
    emit: all
    include_tool_calls: true
    include_model_calls: true
  metrics:
    - name: proof_lane_coverage
      type: counter
      source: jankurai
    - name: improvement_gain
      type: gauge
      source: tests
    - name: rollback_rejections
      type: counter
      source: approvals
  cost:
    budget: 25
    currency: USD
    alert_at_percent: 80
    on_budget_exceeded: pause
  report:
    format: markdown
    on_complete: true
    on_checkpoint: true
    include: [summary, proof, rollback, drift]

approvals:
  gates:
    improvement_review:
      required_role: critic
      timeout: 12h
      on_timeout: pause
      decisions: [approve_push, reject_revert, edit]
      require_evidence: [baseline_kpi, after_kpi, behavior_equivalence_proof, burden_delta, candidate_patch]
      auto_approve_if:
        risk_score_lt: 0.10
        all_checks_pass: true

jankurai:
  enabled: true
  root: "."
  audit:
    mode: ratchet
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    sarif: target/jankurai/jankurai.sarif
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: blocker_first
    randomize_ties: true
    max_risk: high
    skip_human_review_required: false
    incubate_risk_at: medium
    defer_rules:
      - HLT-010-SECRET-SPRAWL
      - HLT-021-DESTRUCTIVE-MIGRATION
      - HLT-032-ZYAL-COMPILE-DRIFT
    incubate_rules:
      - HLT-020-CI-HARDENING-GAP
      - HLT-023-INPUT-BOUNDARY-GAP
      - HLT-029-RUST-BAD-BEHAVIOR
  regression:
    main_ref: origin/main
    compare_every_iterations: 5
    mode: guarded
    max_new_hard_findings: 0
    max_score_drop: 0
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "just fast"
      - "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      - "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
    audit_delta: no_new_findings
    rollback_unverified: true
  pool:
    size: 12
    hard_cap: 20
    branch_prefix: zyal
    integration_branch: zyal/integration
    commit_on_green: true
  reviewer:
    enabled: true
    block_promotion: true
    checklist:
      - id: improvement_quality
        review_priority: blocker
      - id: behavior_equivalence
        review_priority: blocker
      - id: burden_risk
        review_priority: blocker
      - id: rollback_plan
        review_priority: blocker

workflow:
  type: state_machine
  initial: inspect
  on_stuck: pause
  max_total_time: 8h
  states:
    inspect:
      agent: plan
      writes: scratch_only
      requires: [improvement_hypothesis, baseline_kpi]
      produces: [candidate_plan]
      transitions:
        - to: prove
          when:
            all_checks_pass: true
    prove:
      agent: build
      writes: isolated_worktree
      requires: [candidate_plan]
      produces: [proof, after_kpi, candidate_patch]
      transitions:
        - to: critic_review
          when:
            evidence_exists: proof
    critic_review:
      agent: critic-review-worker
      writes: scratch_only
      approval: improvement_review
      requires: [proof, after_kpi, candidate_patch]
      produces: [review_decision, rejection_receipt]
      terminal: true

roles:
  list:
    - id: planner
      agent: plan
      permissions: [read, inspect, route]
      description: "Build the next improvement plan."
    - id: builder
      agent: build
      permissions: [read, edit, shell, checkpoint]
      description: "Implement the measurable improvement."
    - id: critic-review-worker
      agent: critic-review-worker
      permissions: [read, inspect, review]
      description: "Approve, edit, or reject the candidate patch."
    - id: researcher
      agent: researcher
      permissions: [read, inspect, route]
      description: "Gather cited evidence for low-regret improvements."

channels:
  list:
    - id: main
      kind: primary
      route: build
      approval: improvement_review
    - id: research
      kind: evidence
      route: research
      approval: improvement_review
    - id: rollback
      kind: safety
      route: build
      approval: improvement_review
    - id: review
      kind: safety
      route: critic-review-worker
      approval: improvement_review

imports:
  list:
    - source: "AGENTS.md"
      optional: false
    - source: "agent/JANKURAI_STANDARD.md"
      optional: false
    - source: "agent/test-map.json"
      optional: false
    - source: "docs/ZYAL/SPEC.md"
      optional: false

reasoning_privacy:
  store_reasoning: false
  redact_chain_of_thought: true
  summaries_only: true

unsupported_feature_policy:
  required: [jankurai, quality, evidence, rollback, dispatch, taint, research]
  optional: [workflow, memory, sandbox, security, observability]
  fail_closed: true
  on_missing: reject

rollback:
  required_when:
    risk_score_gte: 0.25
    touches_paths:
      - "packages/jekko/src/**"
      - "docs/ZYAL/**"
      - "agent/**"
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: revert_commit

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      timeout: 2m
      assert: { exit_code: 0 }
    - command: "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      timeout: 5m
      assert: { exit_code: 0 }
  git:
    add: ["."]
    commit_message: "fix: semantic improvement with proof"
    push: ask

hooks:
  before_checkpoint:
    - run: "mkdir -p .jekko/daemon/improvement-review && git diff -- . > .jekko/daemon/improvement-review/${run.id}-${task.id}.candidate.patch"
      timeout: 2m
      on_fail: pause
  after_checkpoint:
    - run: "test -s .jekko/daemon/improvement-review/${run.id}-${task.id}.candidate.patch"
      timeout: 30s
      on_fail: block_promotion
    - run: "gh pr create --draft --fill --title 'semantic improvement finder (insane)'"
      timeout: 5m
      on_fail: pause

budgets:
  run:
    iterations: 10
    wall_clock: 8h
    on_exhaust: pause
  task:
    iterations: 2
    on_exhaust: park
  iteration:
    tool_calls: 30
    diff_lines: 800
    on_exhaust: pause

requirements:
  must:
    - read AGENTS.md, agent/JANKURAI_STANDARD.md, and agent/test-map.json first
    - record the improvement hypothesis and baseline KPI before editing
    - save the candidate patch under .jekko/daemon/improvement-review/ before promotion
    - write a behavior-equivalence proof before the patch is promoted
    - use agent/test-map.json for proof routing
    - record rollback notes and the rollback patch command
    - keep the patch minimal and scoped
    - write a rejection receipt under .jekko/daemon/improvement-review/ when a review rejects

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow
  mcp: allow

ui:
  theme: jekko-gold
  banner: forever
<<<END_ZYAL id=semantic-improvement-finder-insane>>>
ZYAL_ARM RUN_FOREVER id=semantic-improvement-finder-insane
