# ZYAL v2.6 - Advanced semantic improvement finder
#
# Weighted triage with Jankurai proof routing, experiment lanes, memory, taint,
# rollback, and host-enforced review gates.

<<<ZYAL v1:daemon id=semantic-improvement-finder-advanced>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Semantic improvement finder advanced"
  objective: |
    Triage low-risk improvements by weight, read the repo instructions before
    editing, route risky improvements into the proof lane, and promote only
    when the improvement hypothesis, baseline KPI, behavior-equivalence proof,
    after KPI, burden delta, rollback note, and PR evidence are all present.
  risk:
    - weighted triage can hide false greens if proof routes are not consulted
    - risky simplifications can bypass review unless taint and rollback stay active

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, host_ui_button, signed_cli_input]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 4s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

stop:
  all:
    - git_clean:
        allow_untracked: false

context:
  strategy: hybrid
  compact_every: 3
  hard_clear_every: 6
  preserve:
    - objective
    - current_improvement
    - improvement_hypothesis
    - baseline_kpi
    - proof_lane
    - rollback_note

hooks:
  on_start:
    - run: "cat AGENTS.md"
      timeout: 30s
      on_fail: pause
    - run: "cat agent/JANKURAI_STANDARD.md"
      timeout: 30s
      on_fail: pause
    - run: "cat agent/test-map.json"
      timeout: 30s
      on_fail: pause
  after_checkpoint:
    - run: "gh pr create --draft --fill --title 'semantic improvement finder (advanced)'"
      timeout: 5m
      on_fail: pause

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_substitutes: true
    block_ts_ignore: true
  diff_budget:
    max_files_changed: 12
    max_added_lines: 500
    on_violation: require_approval
  checks:
    - name: no-test-skip
      pattern: "\\.skip\\(|test\\.only\\(|describe\\.only\\("
      scope: file_diff
      on_violation: block_promotion
    - name: no-false-green
      pattern: "expect\\(true\\)|always passes"
      scope: file_diff
      on_violation: warn

capabilities:
  default: deny
  rules:
    - id: read-repo-guidance
      tool: read
      paths: ["AGENTS.md", "agent/JANKURAI_STANDARD.md", "agent/test-map.json"]
      decision: allow
    - id: edit-jekko-and-docs
      tool: edit
      paths: ["packages/jekko/src/**", "docs/ZYAL/**", "agent/test-map.json"]
      decision: allow
    - id: shell-proof
      tool: shell
      command_regex: "^(bun (test|\\./script/generate-zyal-spec.ts)|just (fast|score)|git (status|diff))"
      decision: allow
      expires: 6h
    - id: pr-hook
      tool: shell
      command_regex: "^gh pr create"
      decision: ask
      require_gate: pr_review
  command_floor:
    always_block:
      - "git push --force"
      - "rm -rf /"

fleet:
  max_workers: 3
  isolation: same_session

jankurai:
  enabled: true
  root: "."
  audit:
    mode: guarded
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    sarif: target/jankurai/jankurai.sarif
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: blocker_first
    randomize_ties: true
    max_risk: medium
    skip_human_review_required: true
    incubate_risk_at: medium
    defer_rules:
      - HLT-010-SECRET-SPRAWL
      - HLT-021-DESTRUCTIVE-MIGRATION
    incubate_rules:
      - HLT-020-CI-HARDENING-GAP
      - HLT-023-INPUT-BOUNDARY-GAP
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "just fast"
      - "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
    audit_delta: no_new_findings
    rollback_unverified: true

experiments:
  strategy: disjoint_tournament
  fork_from: last_green_checkpoint
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.3
    axes: [simplification, speed, memory, security, burden]
  lanes:
    - id: safe_simplification
      hypothesis: "The best improvement removes code while preserving behavior and extension seams."
      isolation: git_worktree
      timeout: 30m
      budget:
        max_iterations: 2
        max_diff_lines: 250
        max_cost_usd: 1.25
    - id: speed_profile
      hypothesis: "Profile-guided speedups beat speculative rewrites."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 300
        max_cost_usd: 1.50
    - id: memory_reduction
      hypothesis: "Peak-memory improvements should be measured on deterministic fixtures."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 275
        max_cost_usd: 1.50
    - id: security_hardening
      hypothesis: "Security improvements should shrink the permission surface without burden growth."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 250
        max_cost_usd: 1.25
    - id: dependency_surface
      hypothesis: "Reducing dependency surface lowers burden and review cost."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 250
        max_cost_usd: 1.25
  max_parallel: 3
  scoring:
    weights:
      tests_passed: 0.25
      kpi_gain: 0.2
      behavior_equivalence: 0.2
      complexity_reduction: 0.15
      security_delta: 0.1
      rollback_simplicity: 0.1
    primary: best_verified_improvement
    goal_direction: maximize
    judge:
      agent: critic
      blind: true
      must_use_different_provider: true
  reduce:
    strategy: best_verified_patch
    require_final_verification: true
  preserve_failed_lanes_as_negative_memory: true

memory:
  stores:
    counterexamples:
      scope: task
      retention: until_archive
      write_policy: append_only
      read_policy: inject_at_start
      searchable: true
    proofs:
      scope: repo
      retention: permanent
      write_policy: upsert
      read_policy: search
      searchable: true
    improvement_receipts:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
    rollback_notes:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
  redaction:
    patterns:
      - "(token|secret|password|credential)"
    action: mask
  provenance:
    track_source: true
    hash_chain: true

evidence:
  require_before_promote:
    - type: improvement_hypothesis
      must_exist: true
    - type: baseline_kpi
      must_exist: true
    - type: after_kpi
      must_exist: true
    - type: behavior_equivalence_proof
      must_pass: true
    - type: kpi_delta
      must_exist: true
    - type: burden_delta
      must_exist: true
    - type: proof_command
      must_pass: true
    - type: rollback_note
      must_exist: true
    - type: pr_evidence
      must_exist: true

taint:
  default_label: untrusted
  labels:
    untrusted:
      rank: untrusted
    untrusted_for_arming:
      rank: untrusted_for_arming
    trusted_user:
      rank: high
    repo_file:
      rank: medium
    tool_output:
      rank: untrusted
    web_content:
      rank: untrusted_for_arming
    assistant_generated:
      rank: untrusted
    hostile:
      rank: hostile
  forbid:
    - from: [untrusted, untrusted_for_arming, hostile]
      cannot: [arm, approve, grant_capability, write_memory_procedural, exec_shell, install_skill, modify_objective, expose_secret]
      unless: [signed_sanitizer]
  prompt_injection:
    detect_patterns:
      - "[Ii]gnore previous instructions"
      - "[Ss]ystem prompt"
      - "[Tt]ool output"
    on_detect: pause
    scan_sources: [tool_output, web_content, mcp_resource]

rollback:
  required_when:
    risk_score_gte: 0.35
    touches_paths:
      - "packages/jekko/src/**"
      - "docs/ZYAL/**"
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: revert_commit

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      timeout: 2m
      assert: { exit_code: 0 }
  git:
    add: ["."]
    commit_message: "fix: semantic improvement with proof"
    push: ask

requirements:
  must:
    - read AGENTS.md, agent/JANKURAI_STANDARD.md, and agent/test-map.json first
    - record the improvement hypothesis and baseline KPI before editing
    - write a behavior-equivalence proof before the patch is promoted
    - use agent/test-map.json for proof routing
    - record rollback notes and the rollback patch command
    - keep the patch minimal and scoped
    - write a rejection receipt under .jekko/daemon/improvement-review/ when a review rejects

budgets:
  run:
    iterations: 10
    wall_clock: 2h
    on_exhaust: pause
  task:
    iterations: 2
    on_exhaust: park
  iteration:
    tool_calls: 25
    diff_lines: 600
    on_exhaust: pause

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow

ui:
  theme: jekko-gold
  banner: forever
<<<END_ZYAL id=semantic-improvement-finder-advanced>>>
ZYAL_ARM RUN_FOREVER id=semantic-improvement-finder-advanced
