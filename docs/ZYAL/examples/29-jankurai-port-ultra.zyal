# Jankurai port ultra: 20 workers, dispatch, research, taint, memory, reviewer.
<<<ZYAL v1:daemon id=jankurai-port-ultra>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Jankurai port ultra"
  objective: |
    Run the full jankurai forever loop with dispatch, 20 worktree workers,
    concept and receipt memory, external research gates, taint quarantine,
    and reviewer-backed promotion blocking. Commit verified reversible slices
    frequently on jankurai_port so a later plan failure can be reverted and
    retried without losing the good work.

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, signed_cli_input, host_ui_button]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 5s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

context:
  strategy: hybrid
  compact_every: 4
  hard_clear_every: 8
  preserve: [objective, current_finding, current_lane, invariant, proof_command]

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow
  mcp: allow
  research: allow
  websearch: allow
  webfetch: allow

fleet:
  max_workers: 20
  isolation: git_worktree
  jnoccio:
    enabled: true
    base_url: "http://127.0.0.1:4317"
    register_workers: true
    heartbeat_interval: 20s
    max_instances: 20

dispatch:
  enabled: true
  classifier:
    command: "node scripts/jankurai-dispatch-classifier.mjs"
    timeout: 30s
    write_to: target/jankurai/dispatch/route.json
  lanes:
    - id: fan_out
      dispatch_to: fan_out
      description: "Low-risk parallel repairs"
    - id: incubator
      dispatch_to: incubator
      description: "Risky or ambiguous work"
    - id: research
      dispatch_to: research
      description: "External evidence and spec drift"
    - id: review
      dispatch_to: approvals.gates.human_review
      description: "Human escalation"
    - id: sandbox
      dispatch_to: sandbox
      description: "Tainted or untrusted inputs"
  default_lane: fan_out
  on_no_match: default

memory:
  stores:
    shared_blocked_reasons:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: search
      searchable: true
    completed_receipts:
      scope: run
      retention: session
      write_policy: upsert
      read_policy: search
      searchable: true
    regression_sentinel:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: search
      searchable: true
    concept_memory:
      scope: global
      retention: permanent
      write_policy: upsert
      read_policy: search
      searchable: true
      path: "~/.jankurai/concepts/"

taint:
  default_label: clean
  labels:
    clean:
      rank: high
      notes: "Trusted repo state"
    worker_output:
      rank: medium
      notes: "Worker-produced diffs and receipts"
    web_content:
      rank: untrusted
      notes: "External research results"
    secrets:
      rank: hostile
      notes: "Never arm or expose"
    jankurai_port:
      rank: medium
      notes: "Integration branch worktree"
  forbid:
    - from: [web_content, secrets]
      cannot: [arm, approve, grant_capability, exec_shell, expose_secret]
    - from: [worker_output]
      cannot: [expose_secret]
  prompt_injection:
    detect_patterns:
      - "(?:[iI]gnore previous instructions)"
      - "(?:[sS]ystem prompt)"
      - "(?:[rR]eveal secrets)"
    on_detect: block
    scan_sources: [web_content, worker_output]

research:
  version: v1
  mode: mixed
  autonomy: require_plan
  max_parallel: 8
  timeout_seconds: 30
  provider_policy:
    prefer: [official_api, primary_source, privacy_first]
    allow: [openalex, crossref, arxiv, pubmed, gdelt, brave, tavily, exa, searxng, firecrawl, jina, github]
    missing_provider: skip_with_receipt
  extraction:
    enabled: true
    max_pages: 12
    allowed_extractors: [built_in, jina, firecrawl]
  evidence:
    require_citations: true
    claim_level: true
    store: sqlite
  safety:
    redact_secrets: true
    block_internal_urls: true
    prompt_injection: quarantine
    taint_label: web_content
  budgets:
    max_queries: 24
    max_pages: 20
    max_cost_usd: 1.0

jankurai:
  enabled: true
  root: "."
  bootstrap:
    run_update_on_start: true
    ensure_init: true
    ensure_canonical: true
    yes: true
  pool:
    size: 20
    hard_cap: 20
    branch_prefix: "zyal/jankurai-port"
    integration_branch: "jankurai_port"
    commit_on_green: true
  audit:
    mode: advisory
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: quick_wins_first
    randomize_ties: true
    max_risk: medium
    skip_human_review_required: true
    incubate_risk_at: medium
  regression:
    main_ref: origin/main
    compare_every_iterations: 10
    max_new_hard_findings: 0
    max_score_drop: 0
  verification:
    require_clean_start: false
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "just fast"
      - "git diff --check"
    audit_delta: no_new_findings
    rollback_unverified: true

experiments:
  strategy: portfolio_search
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.45
    axes:
      - edit_order
      - verification_order
      - lane_split
  lanes:
    - id: plan-scout
      hypothesis: "Find the safest cap refactor shape before touching code."
      prompt_strategy: default
      isolation: same_session
      timeout: 10m
    - id: plan-audit
      hypothesis: "Audit the plan against regression and proof requirements."
      prompt_strategy: default
      isolation: same_session
      timeout: 10m
    - id: plan-fuse
      hypothesis: "Fuse the strongest plan fragments into one highest-confidence path."
      prompt_strategy: default
      isolation: same_session
      timeout: 10m
    - id: plan-spike
      hypothesis: "Spike an alternate approach when the refactor is unexpectedly broad."
      prompt_strategy: default
      isolation: same_session
      timeout: 10m
  fork_from: current_head
  max_parallel: 4
  scoring:
    command: "just fast"
    goal_direction: maximize
  reduce:
    strategy: synthesize_best
    require_final_verification: true
  on_partial_failure: continue
  preserve_failed_lanes_as_negative_memory: true

incubator:
  enabled: true
  strategy: generate_pool_strengthen
  route_when:
    any:
      - risk_score_gte: 0.45
      - repeated_attempts_gte: 2
      - no_progress_iterations_gte: 2
  budget:
    max_passes_per_task: 8
    max_rounds_per_task: 2
    max_active_tasks: 3
    max_parallel_idea_passes: 4
  scratch:
    storage: sqlite
    mirror: true
    cleanup: summarize_and_archive
  cleanup:
    summarize_to_task_memory: true
    archive_artifacts: true
    delete_scratch: true
  readiness:
    promote_at: 0.8
    model_confidence_cap: 0.08
  passes:
    - id: scout
      type: scout
      context: blind
      writes: scratch_only
    - id: idea
      type: idea
      context: blind
      count: 3
      writes: scratch_only
    - id: strengthen
      type: strengthen
      context: inherit
      reads: [current_best]
      writes: scratch_only
    - id: critique
      type: critic
      context: pool
      reads: [candidate_pool]
      writes: scratch_only
    - id: prototype
      type: prototype
      context: inherit
      reads: [current_best]
      writes: isolated_worktree
    - id: critical-review
      type: critical_reviewer
      context: critic
      writes: scratch_only
    - id: review
      type: promotion_review
      context: promotion
      reads: [current_best]
      writes: scratch_only
    - id: compress
      type: compress
      context: promotion
      writes: scratch_only
  promotion:
    promote_at: 0.8
    require: [problem_statement, current_best_plan, verification_strategy, risk_review]
    block_on:
      unresolved_critical_objections_gte: 1

approvals:
  gates:
    human_review:
      required_role: reviewer
      timeout: 12h
      decisions: [approve, reject]
      require_evidence: [target/jankurai/repo-score.json, target/jankurai/repair-plan.json]

evidence:
  require_before_promote:
    - type: audit
      must_pass: true
      must_exist: true
    - type: regression
      must_pass: true
      must_exist: true
  bundle_format: json
  sign: sha256
  archive: true

budgets:
  run:
    wall_clock: 24h
    cost_usd: 80.00
    on_exhaust: renew_with_approval
  task:
    iterations: 12
    cost_usd: 4.00
    on_exhaust: park
  iteration:
    tool_calls: 40
    diff_lines: 800
    on_exhaust: pause

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_substitutes: true
    block_ts_ignore: true
    require_root_cause_for_bugfix: true
    require_failing_test_first_for_bugfix: true
  diff_budget:
    max_files_changed: 20
    max_added_lines: 1200
    on_violation: require_approval

observability:
  metrics:
    - name: jankurai_score
      type: gauge
      source: target/jankurai/repo-score.json
    - name: active_workers
      type: gauge
      source: daemon.workers.active
  report:
    format: markdown
    on_complete: true
    on_checkpoint: true

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "just fast"
      timeout: 20m
    - command: "git diff --check"
      timeout: 2m
  git:
    add: ["."]
    commit_message: "jankurai(port): ${task.id}"
    push: ask

stop:
  all:
    - shell:
        command: "test -f .jekko/daemon-stop"
        timeout: 10m
    - git_clean:
        allow_untracked: false

done:
  require:
    - stop_conditions_met
    - evidence_complete
  forbid:
    - model_only_claim
    - tests_not_run

ui:
  theme: jekko-gold
  banner: forever
<<<END_ZYAL id=jankurai-port-ultra>>>
ZYAL_ARM RUN_FOREVER id=jankurai-port-ultra
