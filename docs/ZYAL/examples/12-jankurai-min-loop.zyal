# Continuous low-risk jankurai repair loop.
<<<ZYAL v1:daemon id=jankurai-continuous-repair>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Jankurai continuous repair"
  objective: |
    Continuously audit this repository with jankurai, ingest repair-plan
    packets, repair low-risk agent-assisted findings with ten isolated
    workers, verify every candidate, commit verified changes, and push when
    allowed. Stop only when jankurai reports zero findings and git is clean.

    Repair strategy: quick_wins_first ordering, ties randomized, max_risk=low.
    Skip findings flagged human_review_required; defer HLT-010-SECRET-SPRAWL.
    Each worker uses git_worktree isolation to prevent concurrent conflicts.
    Verification: re-run jankurai after candidate fix, require no_new_findings.
    Also run just fast to catch regressions before committing any change.
    Circuit breaker trips on max_consecutive_errors=3, then pauses the loop.

    Observability: emit all spans, include_tool_calls=true, report on checkpoint.
    Metrics tracked: jankurai_score gauge, jankurai_queue_depth gauge.
    On checkpoint: add all staged changes, commit with message verified-repair,
    push only when git_push permission is explicitly granted.

    Workers, repairers, and verifiers share a single lock-file per target path.
    Each worker's sandbox is torn down, commits are squashed, changes rebased.
    On failure: save repair state, emit diagnostic spans, wait for human review.
    Stop conditions: jankurai audit reports zero findings AND git status is clean.

loop:
  policy: forever
  sleep: 5s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

fleet:
  max_workers: 10
  isolation: git_worktree

agents:
  workers:
    - id: jankurai-low-risk
      count: 10
      agent: build
      isolation: git_worktree

jankurai:
  enabled: true
  root: "."
  audit:
    mode: advisory
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    no_score_history: true
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: quick_wins_first
    randomize_ties: true
    max_risk: low
    skip_human_review_required: true
    defer_rules: [HLT-010-SECRET-SPRAWL]
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "just fast"
    audit_delta: no_new_findings
    rollback_unverified: true

stop:
  all:
    - shell:
        command: "jankurai audit . --mode advisory --json target/jankurai/repo-score.json --md target/jankurai/repo-score.md --repair-queue-jsonl target/jankurai/repair-queue.jsonl --no-score-history >/dev/null 2>&1 && jq -e '(.findings // []) | length == 0' target/jankurai/repo-score.json"
        timeout: 10m
    - git_clean:
        allow_untracked: false

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "just fast"
      timeout: 20m
  git:
    add: ["."]
    commit_message: "jankurai: verified low-risk repair"
    push: allow

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: allow
  workers: allow

observability:
  spans:
    emit: all
    include_tool_calls: true
  metrics:
    - name: jankurai_score
      type: gauge
      source: target/jankurai/repo-score.json
    - name: jankurai_queue_depth
      type: gauge
      source: daemon.tasks
  report:
    format: markdown
    on_checkpoint: true

unsupported_feature_policy:
  required: [jankurai]
  fail_closed: true
  on_missing: reject
<<<END_ZYAL id=jankurai-continuous-repair>>>
ZYAL_ARM RUN_FOREVER id=jankurai-continuous-repair
