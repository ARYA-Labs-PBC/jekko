# ZYAL v2.6 - Advanced semantic feature maker
#
# Weighted feature triage with repo intelligence, proof-map-backed Jankurai
# verification, tainted external research, and explicit feature-review gates.

<<<ZYAL v1:daemon id=semantic-feature-maker-advanced>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Semantic feature maker advanced"
  objective: |
    Classify feature opportunities by category, build an atlas from the repo
    surface, quarantine tainted research, route risky work through proof lanes,
    implement the first vertical slice, validate the integration path, and
    only promote when the thesis, evidence, tests, proof command, rollback
    note, and draft PR evidence all line up.
  risk:
    - weighted triage can hide false greens if proof routes are too shallow
    - competitor research can contaminate the feature thesis without taint quarantine
    - the first slice can drift into a broad rewrite unless scope control stays active

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, host_ui_button, signed_cli_input]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 4s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

stop:
  all:
    - git_clean:
        allow_untracked: false
    - shell:
        command: "test -f docs/ZYAL/FEATURE_MAKER.md && test -f target/zyal/feature-maker/critic-review.md && test -f target/zyal/feature-maker/proof-report.md"
        timeout: 5m
        assert:
          exit_code: 0

context:
  strategy: hybrid
  compact_every: 3
  hard_clear_every: 6
  preserve:
    - objective
    - feature_thesis
    - capability_gap
    - research_notes
    - proof_command
    - rollback_note

models:
  profiles:
    plan:
      provider: anthropic
      model: claude-opus-4-7
      reasoning: true
    build:
      provider: anthropic
      model: claude-sonnet-4-6
    critic:
      provider: openai
      model: gpt-5
      reasoning: true
    researcher:
      provider: google
      model: gemini-2-pro
  routes:
    plan: plan
    implement: build
    review: critic
    research: researcher
  critic:
    must_differ_from_builder: true
    must_use_different_provider: true
  redundancy:
    on_rate_limit: plan
    on_context_overflow: critic
    chain: [plan, build, critic]
    cooldown: 30s
  confidence_cap: 0.45

repo_intelligence:
  scale: large
  indexes:
    - README.md
    - MISSION.md
    - ROADMAP.md
    - docs/adr/
    - packages/
    - crates/
    - routes/
    - api/
    - db/migrations/
    - tests/
    - .github/workflows/
    - Dockerfile
    - target/zyal/feature-maker/
  generated_zones:
    - target/zyal/feature-maker/project-atlas.json
    - target/zyal/feature-maker/capability-graph.json
    - target/zyal/feature-maker/opportunity-bank.md
    - target/zyal/feature-maker/feature-dossier.md
    - target/zyal/feature-maker/critic-review.md
    - target/zyal/feature-maker/proof-report.md
  scope_control:
    require_scope_before_edit: true
    max_initial_scope_files: 8
    expand_scope_requires_evidence: true
  blast_radius:
    compute_on: [packages/, crates/, app/, web/]
    pause_when_score_gte: 0.25

dispatch:
  enabled: true
  classifier:
    command: "node scripts/feature-maker-classifier.mjs"
    timeout: 30s
    write_to: target/zyal/feature-maker/dispatch.json
  lanes:
    - id: mission_gap
      dispatch_to: experiments
      description: "Identify feature gaps tied to a mission or roadmap claim."
    - id: latent_data
      dispatch_to: research
      description: "Find data already in the repo that can unlock the feature."
    - id: api_platform
      dispatch_to: fan_out
      description: "Route platform/API work to isolated implementation slices."
    - id: ux_workflow
      dispatch_to: workflow
      description: "Route UX workflow work through the delivery state machine."
    - id: core_ip
      dispatch_to: approvals.gates.feature_review
      description: "Protect core-IP changes behind explicit review."
    - id: enterprise_readiness
      dispatch_to: jankurai
      description: "Stress enterprise risks through proof routing."
    - id: developer_platform
      dispatch_to: experiments
      description: "Validate developer tooling and platform affordances."
    - id: reliability_as_feature
      dispatch_to: sandbox
      description: "Validate reliability or recovery changes in containment."
  default_lane: mission_gap
  on_no_match: default

experiments:
  strategy: portfolio_search
  fork_from: last_green_checkpoint
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.35
    axes: [mission_gap, latent_data, api_platform, ux_workflow, core_ip, enterprise_readiness, developer_platform, reliability_as_feature]
  lanes:
    - id: mission_gap
      hypothesis: "The best feature closes a mission gap with the smallest change set."
      isolation: git_worktree
      timeout: 30m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
    - id: latent_data
      hypothesis: "Features get cheaper when the repo already contains the needed data."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
    - id: api_platform
      hypothesis: "API/platform features should be validated with a first vertical slice."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.75
    - id: ux_workflow
      hypothesis: "Workflow features need user-task evidence before implementation."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.75
    - id: reliability_as_feature
      hypothesis: "Reliability work is a feature when proof and rollback are explicit."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
  max_parallel: 5
  scoring:
    weights:
      tests_passed: 0.25
      user_value: 0.2
      proof_quality: 0.2
      complexity_reduction: 0.15
      rollback_simplicity: 0.1
      integration_coverage: 0.1
    primary: best_verified_patch
    goal_direction: maximize
    judge:
      agent: critic
      blind: true
      must_use_different_provider: true
  reduce:
    strategy: best_verified_patch
    require_final_verification: true
  on_partial_failure: continue
  preserve_failed_lanes_as_negative_memory: true

research:
  version: v1
  mode: mixed
  autonomy: require_plan
  max_parallel: 6
  provider_policy:
    prefer: [official_api, primary_source, privacy_first]
    allow:
      - docs.github.com
      - docs.gitlab.com
      - developer.chrome.com
      - aws.amazon.com
    missing_provider: skip_with_receipt
  extraction:
    enabled: true
    max_pages: 8
    allowed_extractors: [built_in, firecrawl]
  evidence:
    require_citations: true
    claim_level: true
    store: sqlite
  safety:
    redact_secrets: true
    block_internal_urls: true
    prompt_injection: quarantine
    taint_label: web_content
  budgets:
    max_queries: 12
    max_pages: 40
    max_cost_usd: 6
  paper_scan:
    enabled: true
    domains:
      - docs.github.com
      - docs.gitlab.com
      - developer.chrome.com
      - aws.amazon.com
    open_access: preferred
    max_papers: 6
  full_text:
    enabled: true
    store: checked_in_json
    license_policy: public_license_only
  dedupe:
    enabled: true
    state_root: target/zyal/feature-maker/research-dedupe
    duplicate_policy: fail
  context_packing:
    strategy: hard
    target_fill_ratio: 0.8
    output_reserve_tokens: 4096
  audit:
    critics: 2
    focused_auditors: 1
    min_auditor_agreement: 0.75
    min_answerability: 0.9

taint:
  default_label: repo_evidence
  labels:
    repo_evidence:
      rank: high
      notes: Repo facts and checked-in docs.
    feature_thesis:
      rank: medium
      notes: In-repo feature hypotheses still need proof.
    web_content:
      rank: untrusted
      notes: External web evidence is preview-only.
    competitor_research:
      rank: untrusted_for_arming
      notes: Competitor comparisons stay quarantined until review.
  forbid:
    - from: [web_content, competitor_research]
      cannot: [arm, approve, grant_capability, modify_objective]
      unless: [feature_review]
  prompt_injection:
    detect_patterns:
      - "ignore previous instructions"
      - "system prompt"
      - "BEGIN PROMPT"
      - "<script"
    on_detect: pause
    scan_sources: [web_content, mcp_resource]

jankurai:
  enabled: true
  root: "."
  audit:
    mode: guarded
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    sarif: target/jankurai/jankurai.sarif
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: severity_first
    randomize_ties: true
    max_risk: medium
    skip_human_review_required: true
    incubate_risk_at: medium
    defer_rules:
      - HLT-010-SECRET-SPRAWL
      - HLT-021-DESTRUCTIVE-MIGRATION
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      - "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      - "just fast"
    audit_delta: no_new_findings
    rollback_unverified: true

workflow:
  type: state_machine
  initial: discover
  states:
    discover:
      agent: plan
      writes: scratch_only
      produces: [project_atlas, feature_thesis, capability_gap]
      transitions:
        - to: research
          when:
            evidence_exists: project_atlas
    research:
      agent: researcher
      writes: scratch_only
      requires: [project_atlas, feature_thesis]
      produces: [research_notes, proof_plan]
      transitions:
        - to: implement
          when:
            all_checks_pass: true
    implement:
      agent: build
      writes: isolated_worktree
      requires: [feature_thesis, proof_plan, capability_gap]
      produces: [first_vertical_slice, tests_added]
      transitions:
        - to: validate
          when:
            all_checks_pass: true
    validate:
      agent: critic
      writes: scratch_only
      requires: [first_vertical_slice, tests_added]
      produces: [proof_command, rollback_note]
      transitions:
        - to: review
          when:
            approval_granted: feature_review
    review:
      agent: plan
      approval: feature_review
      writes: scratch_only
      requires: [proof_command, rollback_note]
      produces: [pr_evidence]
      terminal: true

evidence_graph:
  nodes:
    mission_link:
      type: doc_claim
      required: true
    capability_gap:
      type: repo_fact
      required: true
    user_workflow:
      type: workflow
      required: true
    first_vertical_slice:
      type: implementation
      required: true
    integration_validation:
      type: verification
      required: true
    proof_plan:
      type: verification
      required: true
  edges:
    - from: mission_link
      to: capability_gap
      kind: implies
    - from: capability_gap
      to: first_vertical_slice
      kind: must_prove
    - from: first_vertical_slice
      to: integration_validation
      kind: validates
    - from: integration_validation
      to: proof_plan
      kind: proves
    - from: user_workflow
      to: proof_plan
      kind: validates
  merge_witness: target/zyal/feature-maker/feature-dossier.md

approvals:
  gates:
    feature_review:
      required_role: reviewer
      timeout: 1d
      on_timeout: escalate
      decisions: [approve_push, reject_revert, edit]
      require_evidence: [feature_thesis, proof_command, pr_evidence]
      auto_approve_if:
        risk_score_lt: 0.15
        all_checks_pass: true
  escalation:
    chain: [reviewer, tech_lead]
    auto_escalate_after: 6h

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_fallback: true
    block_ts_ignore: true
  diff_budget:
    max_files_changed: 12
    max_added_lines: 700
    on_violation: require_approval
  checks:
    - name: no-test-skip
      pattern: "\\.skip\\(|test\\.only\\(|describe\\.only\\("
      scope: file_diff
      on_violation: block_promotion
    - name: no-false-green
      pattern: "expect\\(true\\)|always passes"
      scope: file_diff
      on_violation: warn
    - name: no-contract-drift
      pattern: "SPEC\\.md|VERSION\\.md"
      scope: file_diff
      on_violation: warn

capabilities:
  default: deny
  rules:
    - id: read-governance
      tool: read
      paths:
        - AGENTS.md
        - agent/JANKURAI_STANDARD.md
        - agent/test-map.json
        - docs/ZYAL/SPEC.md
      decision: allow
    - id: proof-shell
      tool: shell
      command_regex: "^(bun|cargo|just) "
      decision: allow
      expires: 6h
    - id: draft-pr
      tool: shell
      command_regex: "^gh pr create"
      decision: ask
      require_gate: feature_review
  command_floor:
    always_block:
      - "git push --force"
      - "rm -rf /"

requirements:
  must:
    - write the feature thesis before editing code
    - quarantine tainted research and cite the provenance
    - keep the first slice behind a proof plan
    - validate the integration path before PR promotion
    - record rollback and draft PR evidence
  should:
    - prefer a small, shippable slice over a broad rewrite
    - keep generated atlas artifacts under target/zyal/feature-maker/
  avoid:
    - generic feature ideas without repo evidence
    - missing tests or missing rollback notes
    - unresolved security or migration risk

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      timeout: 2m
      assert:
        exit_code: 0
    - command: "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      timeout: 10m
      assert:
        exit_code: 0
    - command: "just fast"
      timeout: 15m
      assert:
        exit_code: 0
  git:
    add:
      - docs/ZYAL/examples/25-semantic-feature-maker-advanced.zyal
      - docs/ZYAL/FEATURE_MAKER.md
    commit_message: "docs: feature maker advanced"
    push: ask

rollback:
  required_when:
    risk_score_gte: 0.2
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: feature_flag_off

done:
  require:
    - target/zyal/feature-maker/project-atlas.json
    - target/zyal/feature-maker/capability-graph.json
    - target/zyal/feature-maker/opportunity-bank.md
    - target/zyal/feature-maker/feature-dossier.md
    - target/zyal/feature-maker/critic-review.md
    - target/zyal/feature-maker/proof-report.md
    - docs/ZYAL/FEATURE_MAKER.md
  forbid:
    - broad_rewrite
    - missing_research_receipt
    - missing_rollback_note

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow
  research: allow
  websearch: allow
  webfetch: allow
  mcp: allow

hooks:
  before_checkpoint:
    - run: "mkdir -p .jekko/daemon/feature-review && git diff --binary > .jekko/daemon/feature-review/candidate.patch"
      timeout: 5m
      on_fail: pause
  after_checkpoint:
    - run: "gh pr create --draft --fill --title 'semantic feature maker advanced'"
      timeout: 5m
      on_fail: pause

ui:
  theme: jekko-gold
  banner: feature-maker
<<<END_ZYAL id=semantic-feature-maker-advanced>>>
ZYAL_ARM RUN_FOREVER id=semantic-feature-maker-advanced
