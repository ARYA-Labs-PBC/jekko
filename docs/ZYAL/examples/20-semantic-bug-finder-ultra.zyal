# ZYAL v2.6 - Ultra semantic bug finder
#
# Full-power dispatch, fleet, experiments, research, memory, taint, sandbox,
# security, and contract-drift hunting. Lane set: boundary, negative-test,
# false-green, race/transaction, contract-drift, Docker/runtime, and random
# deep-dive hunting.

<<<ZYAL v1:daemon id=semantic-bug-finder-ultra>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Semantic bug finder ultra"
  objective: |
    Run a full-power bug-finding fleet. Route findings by category, keep
    counterexamples and proofs in memory, quarantine tainted inputs, run
    contract-drift checks, and only promote when tests, proofs, rollback, and
    evidence all line up.
  risk:
    - full-power dispatch can amplify false greens if the proof lane is weak
    - contract drift can hide in generated or runtime-adjacent surfaces

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, host_ui_button, signed_cli_input]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 5s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

stop:
  all:
    - git_clean:
        allow_untracked: false

context:
  strategy: hybrid
  compact_every: 4
  hard_clear_every: 8
  preserve:
    - objective
    - current_bug
    - current_lane
    - invariant
    - counterexample
    - proof_command

dispatch:
  enabled: true
  classifier:
    command: "node scripts/dispatch-classifier.mjs"
    timeout: 30s
    write_to: target/jankurai/dispatch/route.json
  lanes:
    - id: boundary
      dispatch_to: fan_out
      description: "Boundary-condition bugs"
    - id: negative-test
      dispatch_to: experiments
      description: "Build failing tests before the fix"
    - id: false-green
      dispatch_to: approvals.gates.false_green_review
      description: "Detect suspicious passes"
    - id: race-transaction
      dispatch_to: incubator
      description: "Race and transaction hazards"
    - id: contract-drift
      dispatch_to: research
      description: "Spec and generated-output drift"
    - id: docker-runtime
      dispatch_to: sandbox
      description: "Container/runtime mismatch"
    - id: random-deep-dive
      dispatch_to: fan_out
      description: "Random deep-dive hunting"
  default_lane: boundary
  on_no_match: default

fleet:
  max_workers: 12
  isolation: hybrid
  jnoccio:
    enabled: true
    base_url: "http://127.0.0.1:4317"
    register_workers: true
    heartbeat_interval: 20s
    max_instances: 12
  telemetry:
    publish_to: jnoccio
    headers:
      x-jekko-run-id: "${run.id}"
      x-jekko-session: "${session.id}"
      x-jekko-process-role: worker

agents:
  supervisor:
    agent: plan
  workers:
    - id: boundary-worker
      count: 3
      agent: build
      isolation: git_worktree
    - id: negative-test-worker
      count: 2
      agent: build
      isolation: git_worktree
    - id: false-green-worker
      count: 2
      agent: build
      isolation: git_worktree
    - id: race-worker
      count: 2
      agent: build
      isolation: git_worktree
    - id: contract-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: docker-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: deep-dive-worker
      count: 1
      agent: build
      isolation: git_worktree

models:
  profiles:
    plan:
      provider: anthropic
      model: claude-opus-4-7
      reasoning: true
    build:
      provider: anthropic
      model: claude-sonnet-4-6
    critic:
      provider: openai
      model: gpt-5
      reasoning: true
    researcher:
      provider: google
      model: gemini-2-pro
  routes:
    plan: plan
    implement: build
    review: critic
    research: researcher
  critic:
    must_differ_from_builder: true
    must_use_different_provider: true
  redundancy:
    on_rate_limit: plan
    on_context_overflow: critic
    chain: [plan, build, critic]
    cooldown: 30s
  confidence_cap: 0.45

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_fallback: true
    block_ts_ignore: true
    require_root_cause_for_bugfix: true
    require_failing_test_first_for_bugfix: true
  diff_budget:
    max_files_changed: 20
    max_added_lines: 1200
    on_violation: require_approval
  checks:
    - name: no-test-skip
      pattern: "\\.skip\\(|test\\.only\\(|describe\\.only\\("
      scope: file_diff
      on_violation: block_promotion
    - name: no-false-green
      pattern: "expect\\(true\\)|always passes"
      scope: file_diff
      on_violation: warn
    - name: no-contract-drift
      pattern: "SPEC\\.md|VERSION\\.md"
      scope: file_diff
      on_violation: warn

experiments:
  strategy: portfolio_search
  fork_from: last_green_checkpoint
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.35
    axes: [boundary, negative-test, false-green, race, contract-drift, runtime, deep-dive]
  lanes:
    - id: boundary
      hypothesis: "Boundary cases fail first and reveal the smallest fix."
      isolation: git_worktree
      timeout: 30m
      budget:
        max_iterations: 2
        max_diff_lines: 180
        max_cost_usd: 1.50
    - id: negative-test
      hypothesis: "A failing test before the patch prevents false confidence."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.75
    - id: false-green
      hypothesis: "Suspicious passes are easier to catch with guardrail tests."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 160
        max_cost_usd: 1.25
    - id: race-transaction
      hypothesis: "Concurrency and transaction hazards need isolated repros."
      isolation: git_worktree
      timeout: 60m
      budget:
        max_iterations: 3
        max_diff_lines: 250
        max_cost_usd: 2.00
    - id: contract-drift
      hypothesis: "Generated outputs and spec docs must remain in sync."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 220
        max_cost_usd: 1.50
    - id: docker-runtime
      hypothesis: "Runtime and container differences are best verified separately."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 200
        max_cost_usd: 1.50
    - id: random-deep-dive
      hypothesis: "Random deep dives uncover latent semantic bugs."
      isolation: git_worktree
      timeout: 60m
      budget:
        max_iterations: 3
        max_diff_lines: 280
        max_cost_usd: 2.25
  max_parallel: 6
  scoring:
    weights:
      tests_passed: 0.3
      proof_lane_coverage: 0.2
      diff_minimal: 0.15
      runtime_safety: 0.15
      rollback_simplicity: 0.2
    primary: best_verified_patch
    goal_direction: maximize
    judge:
      agent: critic
      blind: true
      must_use_different_provider: true
  reduce:
    strategy: synthesize_best
    require_final_verification: true
  preserve_failed_lanes_as_negative_memory: true

research:
  version: v1
  mode: mixed
  autonomy: require_plan
  max_parallel: 4
  timeout_seconds: 60
  provider_policy:
    prefer: [official_api, primary_source, privacy_first]
    allow: [openalex, arxiv, github, tavily, exa, firecrawl, jina]
    missing_provider: skip_with_receipt
  extraction:
    enabled: true
    max_pages: 10
    allowed_extractors: [built_in, jina]
  evidence:
    require_citations: true
    claim_level: true
    store: sqlite
  safety:
    redact_secrets: true
    block_internal_urls: true
    prompt_injection: quarantine
    taint_label: web_content
  budgets:
    max_queries: 40
    max_pages: 30
    max_cost_usd: 15
  paper_scan:
    enabled: true
    domains: [arxiv.org, openreview.net]
    queries: ["semantic bug finding", "false green testing", "contract drift"]
    open_access: preferred
    max_papers: 8
    output_root: ".jekko/daemon/research"
    raw_receipts: ".jekko/daemon/research/raw"
  full_text:
    enabled: true
    store: checked_in_json
    raw_receipts: ".jekko/daemon/research/raw"
    extraction_receipts: ".jekko/daemon/research/extracted"
    license_policy: oa_only
  dedupe:
    enabled: true
    state_root: ".jekko/daemon/research/dedupe"
    duplicate_policy: skip_existing
    hash_keys: [url, title, publication_hash]
  context_packing:
    strategy: hard
    target_fill_ratio: 0.8
    output_reserve_tokens: 1600
    safe_window_tokens: 800
  question_bank:
    output_root: ".jekko/daemon/question-bank"
    papers_root: ".jekko/daemon/question-bank/papers"
    challenges_root: ".jekko/daemon/question-bank/challenges"
    rejected_root: ".jekko/daemon/question-bank/rejected"
    acceptance:
      min_auditor_agreement: 0.8
      min_answerability: 0.7
      max_blind_correct_rate_for_hard: 0.25
      reject_if_ambiguous: true
  agent_trials:
    question_generators: 2
    answerers: 2
    model_profile: researcher
  audit:
    critics: 2
    focused_auditors: 2
    min_auditor_agreement: 0.8
    min_answerability: 0.7

memory:
  stores:
    counterexamples:
      scope: task
      retention: until_archive
      write_policy: append_only
      read_policy: inject_at_start
      searchable: true
    proofs:
      scope: repo
      retention: permanent
      write_policy: upsert
      read_policy: search
      searchable: true
    contract_notes:
      scope: repo
      retention: permanent
      write_policy: upsert
      read_policy: search
      searchable: true
    regression_receipts:
      scope: run
      retention: session
      write_policy: append_only
      read_policy: on_demand
      searchable: true
  redaction:
    patterns:
      - "(token|secret|password|credential)"
    action: mask
  provenance:
    track_source: true
    hash_chain: true

evidence:
  require_before_promote:
    - type: invariant
      must_exist: true
    - type: counterexample
      must_exist: true
    - type: failing_test
      must_pass: true
    - type: proof_command
      must_pass: true
    - type: pr_evidence
      must_exist: true
    - type: rollback_note
      must_exist: true

taint:
  default_label: untrusted
  labels:
    untrusted:
      rank: untrusted
    untrusted_for_arming:
      rank: untrusted_for_arming
    trusted_user:
      rank: high
    repo_file:
      rank: medium
    tool_output:
      rank: untrusted
    mcp_resource:
      rank: untrusted
    web_content:
      rank: untrusted_for_arming
    assistant_generated:
      rank: untrusted
    hostile:
      rank: hostile
  forbid:
    - from: [untrusted, untrusted_for_arming, hostile]
      cannot: [arm, approve, grant_capability, write_memory_procedural, write_memory_semantic, exec_shell, install_skill, modify_objective, expose_secret]
      unless: [signed_sanitizer]
  prompt_injection:
    detect_patterns:
      - "[Ii]gnore previous instructions"
      - "[Ss]ystem prompt"
      - "[Tt]ool output"
      - "[Ee]xfiltrate"
    on_detect: pause
    scan_sources: [tool_output, web_content, mcp_resource]

sandbox:
  paths:
    - path: "packages/jekko/src/**"
      access: write
    - path: "docs/ZYAL/**"
      access: write
    - path: "agent/**"
      access: write
  network:
    outbound: allowlist
    allowlist: ["http://127.0.0.1:4317", "https://github.com", "https://api.github.com"]
  resources:
    max_file_size: "1000000"
    max_total_disk: "50000000"
    max_memory: "2000000000"
    max_processes: 12
  env_inherit: [PATH, HOME, USER]
  env_deny: [GITHUB_TOKEN, OPENAI_API_KEY, ANTHROPIC_API_KEY]

security:
  trust_zones:
    repo:
      paths: ["packages/jekko/**", "docs/ZYAL/**", "agent/**"]
      require_approval: false
      max_risk_score: 0.5
    generated:
      paths: ["docs/ZYAL/SPEC.md", "agent/repo-score.json", "agent/repo-score.md"]
      require_approval: true
      max_risk_score: 0.1
  injection:
    scan_inputs: true
    scan_outputs: true
    deny_patterns: ["[Ii]gnore previous instructions", "[Ee]xfiltrate", "[Ss]ystem prompt"]
    on_detect: pause
  secrets:
    allowed_env: [PATH, HOME, USER]
    redact_from_logs: true
    rotate_after: 24h

observability:
  spans:
    emit: all
    include_tool_calls: true
    include_model_calls: true
  metrics:
    - name: proof_lane_coverage
      type: counter
      source: jankurai
    - name: false_green_rate
      type: gauge
      source: tests
    - name: contract_drift_count
      type: gauge
      source: docs
  cost:
    budget: 25
    currency: USD
    alert_at_percent: 80
    on_budget_exceeded: pause
  report:
    format: markdown
    on_complete: true
    on_checkpoint: true
    include: [summary, proof, rollback, drift]

approvals:
  gates:
    false_green_review:
      required_role: reviewer
      timeout: 12h
      on_timeout: pause
      decisions: [approve, reject, edit]
      require_evidence: [invariant, counterexample, failing_test]
      auto_approve_if:
        risk_score_lt: 0.15
        all_checks_pass: true

jankurai:
  enabled: true
  root: "."
  audit:
    mode: ratchet
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    sarif: target/jankurai/jankurai.sarif
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: severity_first
    randomize_ties: true
    max_risk: high
    skip_human_review_required: false
    incubate_risk_at: medium
    defer_rules:
      - HLT-010-SECRET-SPRAWL
      - HLT-021-DESTRUCTIVE-MIGRATION
      - HLT-032-ZYAL-COMPILE-DRIFT
    incubate_rules:
      - HLT-020-CI-HARDENING-GAP
      - HLT-023-INPUT-BOUNDARY-GAP
      - HLT-029-RUST-BAD-BEHAVIOR
  regression:
    main_ref: origin/main
    compare_every_iterations: 5
    mode: guarded
    max_new_hard_findings: 0
    max_score_drop: 0
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "just fast"
      - "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      - "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
    audit_delta: no_new_findings
    rollback_unverified: true
  pool:
    size: 12
    hard_cap: 20
    branch_prefix: zyal
    integration_branch: zyal/integration
    commit_on_green: true
  reviewer:
    enabled: true
    block_promotion: true
    checklist:
      - id: boundary_cases
        severity: warning
      - id: false_green_risk
        severity: blocker
      - id: contract_drift
        severity: blocker
      - id: rollback_plan
        severity: blocker

workflow:
  type: state_machine
  initial: inspect
  on_stuck: pause
  max_total_time: 8h
  states:
    inspect:
      agent: plan
      writes: scratch_only
      requires: [invariant, counterexample]
      produces: [failing_test]
      transitions:
        - to: prove
          when:
            all_checks_pass: true
    prove:
      agent: build
      writes: isolated_worktree
      requires: [failing_test]
      produces: [proof]
      transitions:
        - to: verify
          when:
            evidence_exists: proof
    verify:
      agent: critic
      writes: scratch_only
      requires: [proof]
      produces: [pr_evidence]
      terminal: true

requirements:
  must:
    - invariant before edit
    - concrete counterexample before the fix
    - failing test or reproducer before the patch
    - minimal patch only
    - proof command recorded
    - PR evidence bundle recorded
    - rollback note recorded
    - context reset after each bug
    - no bundled multi-bug PRs
  avoid:
    - false green
    - test deletion
    - assertion weakening

roles:
  list:
    - id: planner
      agent: plan
      permissions: [read, inspect, route]
      description: "Build the next bug-finding plan."
    - id: builder
      agent: build
      permissions: [read, edit, shell, checkpoint]
      description: "Implement the minimal fix."

channels:
  list:
    - id: main
      kind: primary
      route: build
      approval: false_green_review
    - id: research
      kind: evidence
      route: research
      approval: false_green_review
    - id: rollback
      kind: safety
      route: build
      approval: false_green_review

imports:
  list:
    - source: "AGENTS.md"
      optional: false
    - source: "agent/test-map.json"
      optional: false
    - source: "docs/ZYAL/SPEC.md"
      optional: false

reasoning_privacy:
  store_reasoning: false
  redact_chain_of_thought: true
  summaries_only: true

unsupported_feature_policy:
  required: [jankurai, quality, evidence, rollback, dispatch, taint, research]
  optional: [workflow, memory, sandbox, security, observability]
  fail_closed: true
  on_missing: reject

rollback:
  required_when:
    risk_score_gte: 0.25
    touches_paths:
      - "packages/jekko/src/**"
      - "docs/ZYAL/**"
      - "agent/**"
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: revert_commit

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      timeout: 2m
      assert: { exit_code: 0 }
    - command: "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      timeout: 5m
      assert: { exit_code: 0 }
  git:
    add: ["."]
    commit_message: "fix: semantic bug with proof"
    push: ask

hooks:
  after_checkpoint:
    - run: "gh pr create --draft --fill --title 'semantic bug fix (ultra)'"
      timeout: 5m
      on_fail: pause

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow
  mcp: allow

ui:
  theme: jekko-gold
  banner: forever
<<<END_ZYAL id=semantic-bug-finder-ultra>>>
ZYAL_ARM RUN_FOREVER id=semantic-bug-finder-ultra
