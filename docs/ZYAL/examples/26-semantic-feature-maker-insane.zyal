# ZYAL v2.6 - Insane semantic feature maker
#
# Full fleet with dispatch, research, memory, workflow, sandbox, security,
# observability, and critic review that can approve push, reject/revert, or
# request edits with a saved candidate patch.

<<<ZYAL v1:daemon id=semantic-feature-maker-insane>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Semantic feature maker insane"
  objective: |
    Run a full-power feature-maker fleet. Build the project atlas, generate a
    capability graph, route features by category, quarantine tainted research,
    save the candidate patch before review, and only promote when evidence,
    tests, proof command, rollback note, critic review, and draft PR evidence
    all line up.
  risk:
    - full-power dispatch can amplify false greens if the proof lane is weak
    - tainted research can leak into promotion unless quarantine is explicit
    - migration or security risk can hide behind a compelling feature thesis

arming:
  preview_hash_required: true
  host_nonce_required: true
  reject_inside_code_fence: true
  reject_from: [assistant_output, tool_output, web_content, mcp_resource]
  accepted_origins: [trusted_user_message, host_ui_button, signed_cli_input]
  arm_token_single_use: true

loop:
  policy: forever
  sleep: 5s
  continue_on: [assistant_stop, max_steps, compaction, checkpoint_failed]
  pause_on: [permission_denied]
  circuit_breaker:
    max_consecutive_errors: 3
    on_trip: pause

stop:
  all:
    - git_clean:
        allow_untracked: false
    - shell:
        command: "test -f docs/ZYAL/FEATURE_MAKER.md && test -f target/zyal/feature-maker/project-atlas-summary.md && test -f target/zyal/feature-maker/proof-report.md && test -f target/zyal/feature-maker/critic-review.md"
        timeout: 5m
        assert:
          exit_code: 0

context:
  strategy: hybrid
  compact_every: 4
  hard_clear_every: 8
  preserve:
    - objective
    - feature_thesis
    - candidate_patch
    - proof_command
    - rollback_note
    - pr_evidence

models:
  profiles:
    plan:
      provider: anthropic
      model: claude-opus-4-7
      reasoning: true
    build:
      provider: anthropic
      model: claude-sonnet-4-6
    critic:
      provider: openai
      model: gpt-5
      reasoning: true
    researcher:
      provider: google
      model: gemini-2-pro
  routes:
    plan: plan
    implement: build
    review: critic
    research: researcher
  critic:
    must_differ_from_builder: true
    must_use_different_provider: true
  redundancy:
    on_rate_limit: plan
    on_context_overflow: critic
    chain: [plan, build, critic]
    cooldown: 30s
  confidence_cap: 0.4

repo_intelligence:
  scale: billion_loc
  indexes:
    - README.md
    - MISSION.md
    - ROADMAP.md
    - docs/adr/
    - packages/
    - crates/
    - routes/
    - api/
    - db/migrations/
    - ui/
    - tests/
    - .github/workflows/
    - Dockerfile
    - target/zyal/feature-maker/
  generated_zones:
    - target/zyal/feature-maker/project-atlas.json
    - target/zyal/feature-maker/project-atlas-summary.md
    - target/zyal/feature-maker/capability-graph.json
    - target/zyal/feature-maker/opportunity-bank.md
    - target/zyal/feature-maker/feature-dossier.md
    - target/zyal/feature-maker/critic-review.md
    - target/zyal/feature-maker/proof-report.md
  scope_control:
    require_scope_before_edit: true
    max_initial_scope_files: 10
    expand_scope_requires_evidence: true
  blast_radius:
    compute_on: [packages/, crates/, app/, web/]
    pause_when_score_gte: 0.2

dispatch:
  enabled: true
  classifier:
    command: "node scripts/feature-maker-classifier.mjs"
    timeout: 30s
    write_to: target/zyal/feature-maker/dispatch.json
  lanes:
    - id: mission_gap
      dispatch_to: experiments
      description: "Mission or roadmap claim that needs a feature."
    - id: latent_data
      dispatch_to: research
      description: "Repo data or logs that can unlock the feature."
    - id: api_platform
      dispatch_to: fan_out
      description: "API and platform slices."
    - id: ux_workflow
      dispatch_to: workflow
      description: "Workflow and user-journey changes."
    - id: core_ip
      dispatch_to: approvals.gates.feature_review
      description: "Core-IP or strategic differentiation."
    - id: enterprise_readiness
      dispatch_to: jankurai
      description: "Enterprise hardening and proof routing."
    - id: developer_platform
      dispatch_to: experiments
      description: "Developer tooling and platform affordances."
    - id: reliability_as_feature
      dispatch_to: sandbox
      description: "Reliability or recovery as a user-facing feature."
    - id: integration
      dispatch_to: workflow
      description: "Cross-system integration and migration work."
    - id: customer_request
      dispatch_to: approvals.gates.feature_review
      description: "Direct customer requests that need human review."
    - id: competitor_research
      dispatch_to: research
      description: "Competitive comparisons and standards checks."
    - id: architecture_incubator
      dispatch_to: incubator
      description: "Architecture questions that need incubation."
    - id: random_deep_dive
      dispatch_to: fan_out
      description: "Unstructured deep-dive feature hunting."
  default_lane: mission_gap
  on_no_match: default

fleet:
  max_workers: 12
  isolation: hybrid
  jnoccio:
    enabled: true
    base_url: "http://127.0.0.1:4317"
    register_workers: true
    heartbeat_interval: 20s
    max_instances: 12
  telemetry:
    publish_to: jnoccio
    headers:
      x-jekko-run-id: "${run.id}"
      x-jekko-session: "${session.id}"
      x-jekko-process-role: worker

agents:
  supervisor:
    agent: plan
  workers:
    - id: atlas-worker
      count: 3
      agent: build
      isolation: git_worktree
    - id: research-worker
      count: 2
      agent: researcher
      isolation: git_worktree
    - id: implementation-worker
      count: 3
      agent: build
      isolation: git_worktree
    - id: review-worker
      count: 1
      agent: critic
      isolation: same_session
    - id: infra-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: integration-worker
      count: 1
      agent: build
      isolation: git_worktree
    - id: deep-dive-worker
      count: 1
      agent: build
      isolation: git_worktree

experiments:
  strategy: portfolio_search
  fork_from: last_green_checkpoint
  diversity:
    require_distinct_plan: true
    min_plan_distance: 0.35
    axes: [mission_gap, latent_data, api_platform, ux_workflow, core_ip, enterprise_readiness, developer_platform, reliability_as_feature]
  lanes:
    - id: mission_gap
      hypothesis: "The best feature closes a mission gap with the smallest change set."
      isolation: git_worktree
      timeout: 30m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.50
    - id: latent_data
      hypothesis: "Features get cheaper when the repo already contains the needed data."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.50
    - id: api_platform
      hypothesis: "API and platform features should be validated with a first vertical slice."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 260
        max_cost_usd: 1.75
    - id: ux_workflow
      hypothesis: "Workflow features need user-task evidence before implementation."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 260
        max_cost_usd: 1.75
    - id: reliability_as_feature
      hypothesis: "Reliability work is a feature when proof and rollback are explicit."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.50
    - id: developer_platform
      hypothesis: "Developer-platform improvements should pay down friction with proof."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 240
        max_cost_usd: 1.50
    - id: enterprise_readiness
      hypothesis: "Enterprise-readiness changes need explicit migration and rollback proof."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 260
        max_cost_usd: 1.75
    - id: core_ip
      hypothesis: "Core-IP features should be proven against mission evidence and review gates."
      isolation: git_worktree
      timeout: 45m
      budget:
        max_iterations: 2
        max_diff_lines: 260
        max_cost_usd: 1.75
  max_parallel: 8
  scoring:
    weights:
      tests_passed: 0.2
      user_value: 0.2
      proof_quality: 0.2
      complexity_reduction: 0.15
      rollback_simplicity: 0.1
      integration_coverage: 0.15
    primary: best_verified_patch
    goal_direction: maximize
    judge:
      agent: critic
      blind: true
      must_use_different_provider: true
  reduce:
    strategy: best_verified_patch
    require_final_verification: true
  on_partial_failure: continue
  preserve_failed_lanes_as_negative_memory: true

research:
  version: v1
  mode: mixed
  autonomy: require_plan
  max_parallel: 8
  provider_policy:
    prefer: [official_api, primary_source, privacy_first]
    allow:
      - docs.github.com
      - docs.gitlab.com
      - developer.chrome.com
      - aws.amazon.com
    missing_provider: skip_with_receipt
  extraction:
    enabled: true
    max_pages: 10
    allowed_extractors: [built_in, firecrawl, jina]
  evidence:
    require_citations: true
    claim_level: true
    store: sqlite
  safety:
    redact_secrets: true
    block_internal_urls: true
    prompt_injection: quarantine
    taint_label: web_content
  budgets:
    max_queries: 16
    max_pages: 48
    max_cost_usd: 8
  paper_scan:
    enabled: true
    domains:
      - docs.github.com
      - docs.gitlab.com
      - developer.chrome.com
      - aws.amazon.com
    open_access: preferred
    max_papers: 8
  full_text:
    enabled: true
    store: checked_in_json
    license_policy: public_license_only
  dedupe:
    enabled: true
    state_root: target/zyal/feature-maker/research-dedupe
    duplicate_policy: fail
  context_packing:
    strategy: hard
    target_fill_ratio: 0.8
    output_reserve_tokens: 4096
  audit:
    critics: 3
    focused_auditors: 2
    min_auditor_agreement: 0.8
    min_answerability: 0.9

memory:
  stores:
    opportunity_bank:
      scope: run
      retention: until_archive
      max_entries: 500
      compression: summary
      write_policy: append_only
      read_policy: search
      searchable: true
      path: target/zyal/feature-maker/opportunity-bank.md
    feature_dossier:
      scope: repo
      retention: permanent
      max_entries: 200
      compression: summary
      write_policy: append_only
      read_policy: on_demand
      searchable: true
      path: target/zyal/feature-maker/feature-dossier.md
    critic_review:
      scope: task
      retention: session
      max_entries: 200
      compression: summary
      write_policy: append_only
      read_policy: search
      searchable: true
      path: target/zyal/feature-maker/critic-review.md
  redaction:
    patterns:
      - secret
      - token
      - password
      - API_KEY
    action: hash
  provenance:
    track_source: true
    hash_chain: true

sandbox:
  paths:
    - path: docs/ZYAL/**
      access: read
    - path: target/zyal/feature-maker/**
      access: write
    - path: .jekko/daemon/feature-review/**
      access: write
    - path: packages/jekko/src/**
      access: write
    - path: crates/**
      access: write
    - path: .github/workflows/**
      access: read
  network:
    outbound: allowlist
    allowlist:
      - https://api.github.com
      - https://docs.github.com
      - https://developer.mozilla.org
  resources:
    max_file_size: 2MB
    max_total_disk: 1GB
    max_memory: 2GB
    max_processes: 12
  env_inherit:
    - HOME
    - PATH
    - GITHUB_TOKEN
    - JNOCCIO_REPO_ROOT
  env_deny:
    - OPENAI_API_KEY
    - AWS_SECRET_ACCESS_KEY

security:
  trust_zones:
    feature_maker_docs:
      paths:
        - docs/ZYAL/**
        - target/zyal/feature-maker/**
      require_approval: true
      max_risk_score: 0.2
    source_tree:
      paths:
        - packages/jekko/src/**
        - crates/**
      require_approval: false
      max_risk_score: 0.35
  injection:
    scan_inputs: true
    scan_outputs: true
    deny_patterns:
      - ignore previous instructions
      - secret
      - token
      - password
      - BEGIN PROMPT
    on_detect: abort
  secrets:
    allowed_env:
      - GITHUB_TOKEN
      - JNOCCIO_REPO_ROOT
      - HOME
      - PATH
    redact_from_logs: true
    rotate_after: 24h

observability:
  spans:
    emit: all
    include_tool_calls: true
    include_model_calls: false
  metrics:
    - name: feature_thesis_count
      type: counter
      source: target/zyal/feature-maker/feature-dossier.md
    - name: proof_lane_pass_rate
      type: gauge
      source: target/zyal/feature-maker/proof-report.md
  cost:
    budget: 12
    currency: usd
    alert_at_percent: 80
    on_budget_exceeded: pause
  report:
    format: markdown
    on_complete: true
    on_checkpoint: true
    include:
      - thesis
      - tests
      - proof
      - rollback

taint:
  default_label: repo_evidence
  labels:
    repo_evidence:
      rank: high
      notes: Repository facts and verified docs.
    feature_thesis:
      rank: medium
      notes: In-repo feature hypotheses still need proof.
    web_content:
      rank: untrusted
      notes: External web evidence is preview-only.
    competitor_research:
      rank: untrusted_for_arming
      notes: Competitor comparisons stay quarantined until review.
  forbid:
    - from: [web_content, competitor_research]
      cannot: [arm, approve, grant_capability, modify_objective, exec_shell]
      unless: [feature_review]
    - from: [web_content]
      cannot: [write_memory_semantic, write_memory_procedural]
      unless: [feature_review]
  prompt_injection:
    detect_patterns:
      - "ignore previous instructions"
      - "system prompt"
      - "BEGIN PROMPT"
      - "<script"
      - "assistant:"
    on_detect: pause
    scan_sources: [web_content, mcp_resource]

jankurai:
  enabled: true
  root: "."
  bootstrap:
    run_update_on_start: true
    ensure_init: true
    ensure_canonical: true
    yes: true
    strict: true
  pool:
    size: 12
    hard_cap: 12
    branch_prefix: zyal
    integration_branch: feature-maker/integration
    commit_on_green: true
  reviewer:
    enabled: true
    block_promotion: true
    checklist:
      - id: evidence_present
        prompt: "Is the feature thesis backed by repo evidence?"
        severity: blocker
      - id: workflow_present
        prompt: "Is there a concrete user workflow?"
        severity: blocker
      - id: proof_plan_present
        prompt: "Is the proof plan specific and runnable?"
        severity: blocker
      - id: rewrite_scope
        prompt: "Is the change narrow instead of a broad rewrite?"
        severity: blocker
      - id: core_ip_link
        prompt: "Is the feature linked to core IP or mission value?"
        severity: blocker
      - id: risk_open
        prompt: "Are security or migration risks unresolved?"
        severity: blocker
  audit:
    mode: guarded
    json: target/jankurai/repo-score.json
    md: target/jankurai/repo-score.md
    repair_queue_jsonl: target/jankurai/repair-queue.jsonl
    sarif: target/jankurai/jankurai.sarif
  repair_plan:
    enabled: true
    json: target/jankurai/repair-plan.json
    md: target/jankurai/repair-plan.md
  task_source: repair_plan
  selection:
    order: severity_first
    randomize_ties: true
    max_risk: critical
    skip_human_review_required: false
    incubate_risk_at: medium
    defer_rules:
      - HLT-010-SECRET-SPRAWL
      - HLT-021-DESTRUCTIVE-MIGRATION
  regression:
    main_ref: origin/main
    compare_every_iterations: 5
    mode: guarded
    max_new_hard_findings: 0
    max_score_drop: 0
  verification:
    require_clean_start: true
    require_clean_after_checkpoint: true
    proof_from_test_map: true
    commands:
      - "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      - "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      - "just fast"
    audit_delta: no_new_findings
    rollback_unverified: true

workflow:
  type: state_machine
  initial: intake
  states:
    intake:
      agent: plan
      writes: scratch_only
      produces: [project_atlas, project_atlas_summary, feature_thesis]
      transitions:
        - to: atlas
          when:
            evidence_exists: project_atlas
    atlas:
      agent: build
      writes: scratch_only
      requires: [project_atlas, feature_thesis]
      produces: [capability_gap, evidence_graph]
      transitions:
        - to: research
          when:
            all_checks_pass: true
    research:
      agent: researcher
      writes: scratch_only
      requires: [capability_gap]
      produces: [research_notes, proof_plan]
      transitions:
        - to: implement
          when:
            all_checks_pass: true
    implement:
      agent: build
      writes: isolated_worktree
      requires: [feature_thesis, proof_plan, capability_gap]
      produces: [first_vertical_slice, tests_added]
      transitions:
        - to: validate
          when:
            all_checks_pass: true
    validate:
      agent: critic
      writes: scratch_only
      requires: [first_vertical_slice, tests_added]
      produces: [proof_command, rollback_note]
      transitions:
        - to: review
          when:
            approval_granted: feature_review
    review:
      agent: plan
      approval: feature_review
      writes: scratch_only
      requires: [proof_command, rollback_note]
      produces: [pr_evidence]
      terminal: true

evidence_graph:
  nodes:
    mission_link:
      type: doc_claim
      required: true
    project_atlas_summary:
      type: repo_fact
      required: true
    capability_gap:
      type: repo_fact
      required: true
    user_workflow:
      type: workflow
      required: true
    first_vertical_slice:
      type: implementation
      required: true
    integration_validation:
      type: verification
      required: true
    proof_plan:
      type: verification
      required: true
    pr_evidence:
      type: evidence
      required: true
  edges:
    - from: mission_link
      to: capability_gap
      kind: implies
    - from: capability_gap
      to: first_vertical_slice
      kind: must_prove
    - from: first_vertical_slice
      to: integration_validation
      kind: validates
    - from: integration_validation
      to: proof_plan
      kind: proves
    - from: user_workflow
      to: proof_plan
      kind: validates
    - from: proof_plan
      to: pr_evidence
      kind: must_exist
  merge_witness: target/zyal/feature-maker/feature-dossier.md

approvals:
  gates:
    feature_review:
      required_role: reviewer
      timeout: 1d
      on_timeout: escalate
      decisions: [approve_push, reject_revert, edit]
      require_evidence:
        - project_atlas_summary
        - feature_thesis
        - proof_command
        - pr_evidence
        - critic_review
      auto_approve_if:
        risk_score_lt: 0.1
        all_checks_pass: true
  escalation:
    chain: [reviewer, architect, product]
    auto_escalate_after: 4h

capabilities:
  default: deny
  rules:
    - id: read-governance
      tool: read
      paths:
        - AGENTS.md
        - agent/JANKURAI_STANDARD.md
        - agent/test-map.json
        - docs/ZYAL/SPEC.md
      decision: allow
    - id: proof-shell
      tool: shell
      command_regex: "^(bun|cargo|just) "
      decision: allow
      expires: 6h
    - id: feature-doc-edit
      tool: edit
      paths:
        - docs/ZYAL/**
        - packages/jekko/src/**
        - target/zyal/feature-maker/**
      decision: allow
    - id: draft-pr
      tool: shell
      command_regex: "^(git push -u origin HEAD && )?gh pr create"
      decision: ask
      require_gate: feature_review
  command_floor:
    always_block:
      - "git push --force"
      - "rm -rf /"

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_fallback: true
    block_ts_ignore: true
  diff_budget:
    max_files_changed: 20
    max_added_lines: 1200
    max_deleted_lines: 400
    on_violation: require_approval
  checks:
    - name: no-test-skip
      pattern: "\\.skip\\(|test\\.only\\(|describe\\.only\\("
      scope: file_diff
      on_violation: block_promotion
    - name: no-false-green
      pattern: "expect\\(true\\)|always passes"
      scope: file_diff
      on_violation: warn
    - name: no-contract-drift
      pattern: "SPEC\\.md|VERSION\\.md"
      scope: file_diff
      on_violation: warn

requirements:
  must:
    - write the feature thesis before editing code
    - quarantine tainted research and cite the provenance
    - save the candidate patch under .jekko/daemon/feature-review/
    - validate the integration path before PR promotion
    - record rollback and critic-review evidence
  should:
    - keep the atlas mirrored into memory
    - keep generated artifacts under target/zyal/feature-maker/
  avoid:
    - generic features without repo evidence
    - broad rewrites or unresolved migration risk
    - missing tests, missing proof plan, or missing rollback notes

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "bun --cwd packages/jekko test src/agent-script/schema-spec.test.ts src/agent-script/parser.test.ts"
      timeout: 2m
      assert:
        exit_code: 0
    - command: "cargo test --manifest-path crates/tuiwright-jekko-unlock/Cargo.toml all_tracked_zyal_files_parse_and_preview"
      timeout: 10m
      assert:
        exit_code: 0
    - command: "just fast"
      timeout: 15m
      assert:
        exit_code: 0
  git:
    add:
      - docs/ZYAL/examples/26-semantic-feature-maker-insane.zyal
      - docs/ZYAL/FEATURE_MAKER.md
    commit_message: "docs: feature maker insane"
    push: ask

rollback:
  required_when:
    risk_score_gte: 0.1
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: revert_commit

done:
  require:
    - target/zyal/feature-maker/project-atlas.json
    - target/zyal/feature-maker/project-atlas-summary.md
    - target/zyal/feature-maker/capability-graph.json
    - target/zyal/feature-maker/opportunity-bank.md
    - target/zyal/feature-maker/feature-dossier.md
    - target/zyal/feature-maker/critic-review.md
    - target/zyal/feature-maker/proof-report.md
    - docs/ZYAL/FEATURE_MAKER.md
    - .jekko/daemon/feature-review/candidate.patch
  forbid:
    - broad_rewrite
    - weak_core_ip_link
    - generic_features
    - missing_candidate_patch
    - unresolved_security_risk
    - missing_pr_evidence

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: ask
  workers: allow
  research: allow
  websearch: allow
  webfetch: allow
  mcp: allow

hooks:
  before_checkpoint:
    - run: "mkdir -p .jekko/daemon/feature-review && git diff --binary > .jekko/daemon/feature-review/candidate.patch"
      timeout: 5m
      on_fail: pause
  after_checkpoint:
    - run: "git push -u origin HEAD && gh pr create --draft --fill --title 'semantic feature maker insane'"
      timeout: 5m
      on_fail: pause

ui:
  theme: jekko-gold
  banner: feature-maker
